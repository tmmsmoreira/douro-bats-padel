# Copy to .env.local for local dev. `.env` is gitignored but committing
# any file that contains real secrets is still a liability — keep real
# values out of version control, including the placeholders below.

# API Configuration
NEXT_PUBLIC_API_URL="http://localhost:4000"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
# Generate a real value with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"

# Google OAuth (Optional — leave empty if not using)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Web Push (VAPID) — public key only; generate with `npx web-push generate-vapid-keys`
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
