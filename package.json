{
  "name": "padel-game-manager",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "db:migrate": "cd apps/api && pnpm prisma migrate dev",
    "db:seed": "cd apps/api && pnpm prisma db seed",
    "db:studio": "cd apps/api && pnpm prisma studio",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "lint": "turbo run lint",
    "prepare": "husky || exit 0",
    "test": "turbo run test",
    "test:cov": "turbo run test:cov"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@turbo/gen": "^2.3.3",
    "@types/jest": "^29",
    "@types/node": "^22",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "husky": "^9.1.7",
    "jest": "^29",
    "jest-environment-jsdom": "^29",
    "lint-staged": "^15.2.11",
    "postcss": "^8.5",
    "prettier": "^3.4.2",
    "tailwindcss": "4.1.16",
    "ts-jest": "^29",
    "turbo": "^2.3.3",
    "typescript": "^5"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "tmp@<=0.2.3": ">=0.2.4",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "next@>=15.6.0-canary.0 <16.1.5": ">=16.1.5",
      "next@>=16.0.0-beta.0 <16.0.11": ">=16.0.11",
      "tar@<7.5.7": ">=7.5.7",
      "next@>=16.0.0-beta.0 <16.1.5": ">=16.1.5",
      "webpack@>=5.49.0 <=5.104.0": ">=5.104.1",
      "webpack@>=5.49.0 <5.104.0": ">=5.104.0",
      "tar@<=7.5.2": ">=7.5.3",
      "tar@<7.5.8": ">=7.5.8",
      "multer@<2.1.0": ">=2.1.0",
      "serialize-javascript@<=7.0.2": ">=7.0.3",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "multer@<2.1.1": ">=2.1.1",
      "tar@<=7.5.9": ">=7.5.10",
      "file-type@>=13.0.0 <21.3.1": ">=21.3.1",
      "tar@<=7.5.10": ">=7.5.11",
      "tar@<=7.5.3": ">=7.5.4",
      "file-type@>=20.0.0 <=21.3.1": ">=21.3.2",
      "next@>=16.0.0-beta.0 <16.1.7": ">=16.1.7",
      "next@>=16.0.1 <16.1.7": ">=16.1.7",
      "effect@<3.20.0": ">=3.20.0",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4"
    }
  }
}
