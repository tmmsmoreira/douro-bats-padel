# Copy to .env for local dev. `.env` is gitignored, but never put real
# production secrets anywhere in the repo — use your deploy target's
# secret store (Fly.io secrets, Railway vars, Vercel env, etc.).

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/padel_manager"

# JWT Configuration — generate both with: openssl rand -base64 48
JWT_SECRET="replace-me"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="replace-me"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
FRONTEND_URL="http://localhost:3000"

# Resend (transactional email)
RESEND_API_KEY=""
EMAIL_FROM="Douro Bats Padel <onboarding@resend.dev>"

# Web Push (VAPID) — generate with `npx web-push generate-vapid-keys`
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# Environment
NODE_ENV="development"

# Player inactivity threshold (days)
INACTIVITY_THRESHOLD_DAYS=90
